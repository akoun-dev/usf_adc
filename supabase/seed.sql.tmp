INSERT INTO "public"."forum_topics" ("id", "title", "content", "category_id", "created_by", "is_pinned", "is_locked", "is_public", "views", "status", "created_at", "updated_at") VALUES
	('ec32aef7-0c4c-4098-a0ef-565baca1a39a', 'Bienvenue sur le forum USF-ADC', 'Bienvenue sur le forum public de la plateforme USF-ADC ! Cette plateforme est d笏慊ｮdi笏慊ｮe 笏愿｡ la collaboration et 笏愿｡ l''笏慊ｮchange d''exp笏慊ｮriences entre les points focaux et les experts des Fonds de Service Universel en Afrique. N''h笏慊ｮsitez pas 笏愿｡ poser vos questions et 笏愿｡ partager vos expertise.', 'dc8a291b-1582-47ca-804a-c44ba44514c7', NULL, true, false, true, 0, 'open', '2026-03-28 08:14:16.752077+00', '2026-03-28 08:14:16.752077+00'),
	('3129a76a-5d77-46da-80c6-3b32df92c47b', 'Strat笏慊ｮgies de financement du FSU', 'Quelles sont les meilleures pratiques pour mobiliser les ressources du Fonds de Service Universel ? Partagez vos exp笏慊ｮriences et vos strat笏慊ｮgies r笏慊ｮussies.', '0d727776-4340-4243-a6ba-c5348e6dccf7', NULL, false, false, true, 0, 'open', '2026-04-02 08:14:16.752077+00', '2026-04-02 08:14:16.752077+00'),
	('d96d7d57-f5a0-48e8-a16e-600ba3d0dfde', 'Probl笏慊ｿmes d''acc笏慊ｿs 笏愿｡ la plateforme', 'Je rencontre des difficult笏慊ｮs pour me connecter 笏愿｡ la plateforme. Comment puis-je r笏慊ｮsoudre ce probl笏慊ｿme ?', 'dc8a291b-1582-47ca-804a-c44ba44514c7', NULL, false, false, true, 0, 'solved', '2026-04-07 08:14:16.752077+00', '2026-04-09 08:14:16.752077+00'),
	('791b3df9-2c37-48da-95d8-b080b4a17aea', 'Utilisation de la 5G pour le FSU', 'Avez-vous des projets de d笏慊ｮploiement 5G utilisant les ressources du FSU ? Partagez les d笏慊ｮtails et les d笏慊ｮfis rencontr笏慊ｮs.', 'a52044c3-85da-4429-b093-44a17a498834', NULL, false, false, true, 0, 'open', '2026-04-12 08:14:16.752077+00', '2026-04-12 08:14:16.752077+00'),
	('103e321f-cdfd-489c-8af3-4a511adaca97', 'Connectivit笏慊ｮ rurale efficace', 'Quelle est la solution la plus rentable pour connecter les zones rurales ? Retours d''exp笏慊ｮrience bienvenus.', 'a52044c3-85da-4429-b093-44a17a498834', NULL, true, false, true, 0, 'open', '2026-04-17 08:14:16.752077+00', '2026-04-19 08:14:16.752077+00'),
	('e036712e-ebb5-4557-8187-fba2e0271b92', 'Gouvernance des FSU', 'Comment garantir une bonne gouvernance des Fonds de Service Universel au niveau national ?', 'b8a69c73-cd53-4580-b978-e6b69e58b10a', NULL, false, false, true, 0, 'open', '2026-04-20 08:14:16.752077+00', '2026-04-20 08:14:16.752077+00'),
	('420a214b-a2da-4286-9747-e9c097a2526c', 'Partnership PPP dans le secteur t笏慊ｮl笏慊ｮcom', 'Exemple de partenariats public-priv笏慊ｮ r笏慊ｮussis pour les t笏慊ｮl笏慊ｮcommunications en Afrique.', '0d727776-4340-4243-a6ba-c5348e6dccf7', NULL, false, false, true, 0, 'open', '2026-04-22 08:14:16.752077+00', '2026-04-23 08:14:16.752077+00'),
	('7b065b8a-eb14-4c36-9ce3-ec9e6baf92de', 'Annonce : Nouvelle version de la plateforme', 'La version 2.0 de la plateforme USF-ADC est maintenant en ligne avec de nombreuses nouvelles fonctionnalit笏慊ｮs.', 'dc8a291b-1582-47ca-804a-c44ba44514c7', NULL, true, false, true, 0, 'open', '2026-04-24 08:14:16.752077+00', '2026-04-24 08:14:16.752077+00');


