INSERT INTO "public"."news" ("id", "title", "excerpt", "content", "category", "source", "image_url", "published_at", "is_public", "author", "read_time", "language", "created_by", "created_at", "updated_at", "status", "featured_image", "meta_description", "meta_keywords", "slug", "sort_order", "is_featured", "allow_comments", "category_id") VALUES
	('d0000000-0000-0000-0000-000000000001', 'Lancement du Fonds de Service Universel pan-africain', 'Une initiative historique pour combler la fracture num笏慊ｮrique en Afrique.', 'L''Union Africaine des T笏慊ｮl笏慊ｮcommunications annonce la cr笏慊ｮation d''un fonds de service universel 笏愿｡ l''笏慊ｮchelle continentale. Ce fonds vise 笏愿｡ financer les infrastructures de t笏慊ｮl笏慊ｮcommunications dans les zones non desservies d''Afrique.', 'financement', 'UAT', 'https://images.unsplash.com/photo-1556761175-b413da4baf72?w=1200', '2026-04-12 08:14:17.863291+00', true, 'UAT Communication', '5 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00', 'draft', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000002', 'Partenariat avec la Banque Mondiale', 'Accord de financement de 500 millions USD pour les infrastructures.', 'La Banque Mondiale s''engage 笏愿｡ soutenir les projets de connectivit笏慊ｮ dans 15 pays africains prioritaires. Ce financement permettra le d笏慊ｮploiement de 10 000 km de fibre optique.', 'partenariat', 'UAT', 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1200', '2026-04-15 08:14:17.863291+00', true, 'UAT Communication', '4 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00', 'draft', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000003', 'Formation des Points Focaux', 'Premi笏慊ｿre session de formation r笏慊ｮussie 笏愿｡ Ouagadougou.', '25 points focaux de 10 pays diff笏慊ｮrents ont particip笏慊ｮ 笏愿｡ la formation sur l''utilisation de la plateforme USF-ADC. Cette session marque le d笏慊ｮbut d''un programme de renforcement des capacit笏慊ｮs.', 'formation', 'UAT', 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=1200', '2026-04-17 08:14:17.863291+00', true, 'UAT Formation', '3 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00', 'draft', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000004', ' d笏慊ｮploiement de la 5G en Afrique : Enjeux et opportunit笏慊ｮs', 'Analyse des d笏慊ｮfis du d笏慊ｮploiement de la 5G sur le continent africain.', 'La 5G repr笏慊ｮsente une opportunit笏慊ｮ unique pour acc笏慊ｮl笏慊ｮrer la transformation num笏慊ｮrique de l''Afrique. Cet article analyse les enjeux r笏慊ｮglementaires, 笏慊ｮconomiques et techniques du d笏慊ｮploiement.', 'innovation', 'UAT', 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=1200', '2026-04-18 08:14:17.863291+00', true, 'Dr. Amadou Diallo', '7 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00', 'draft', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000005', 'Rapport annuel 2025 : Un an de progr笏慊ｿs', 'Bilan des activit笏慊ｮs de l''UAT pour l''ann笏慊ｮe 2025.', 'Le rapport annuel 2025 marque une 笏慊ｮtape significative dans le d笏慊ｮveloppement des t笏慊ｮl笏慊ｮcommunications en Afrique. D笏慊ｮcouvrez les chiffres cl笏慊ｮs et les projets marquants de l''ann笏慊ｮe.', 'rapport', 'UAT', 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1200', '2026-04-19 08:14:17.863291+00', true, 'UAT Communication', '6 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00', 'draft', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000006', 'Nouveau cadre r笏慊ｮglementaire pour le FSU', 'Les pays membres adoptent un cadre r笏慊ｮglementaire harmonis笏慊ｮ.', 'Dans un effort d''harmonisation, les pays membres de l''UAT ont adopt笏慊ｮ un nouveau cadre r笏慊ｮglementaire pour la gestion des Fonds de Service Universel.', 'r笏慊ｿglementation', 'UAT', 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=1200', '2026-04-20 08:14:17.863291+00', true, 'UAT Juridique', '5 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00', 'draft', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000007', 'Connectivit笏慊ｮ des zones rurales : Le mod笏慊ｿle s笏慊ｮn笏慊ｮgalais', 'Comment le S笏慊ｮn笏慊ｮgal r笏慊ｮussit le d笏慊ｮfi de la connectivit笏慊ｮ rurale.', 'Le S笏慊ｮn笏慊ｮgal pr笏慊ｮsente un mod笏慊ｿle innovant de d笏慊ｮploiement d''infrastructures dans les zones rurales, bas笏慊ｮ sur un partenariat public-priv笏慊ｮ efficace.', '笏慊ｮtude', 'UAT', 'https://images.unsplash.com/photo-1531403009284-440f080d1e12?w=1200', '2026-04-21 08:14:17.863291+00', true, 'Marie Kouassi', '8 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00', 'draft', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000008', 'Assembl笏慊ｮe G笏慊ｮn笏慊ｮrale 2026 : Les d笏慊ｮcisions cl笏慊ｮs', 'Compte rendu de l''Assembl笏慊ｮe G笏慊ｮn笏慊ｮrale de Kigali.', 'L''Assembl笏慊ｮe G笏慊ｮn笏慊ｮrale 2026 a pris plusieurs d笏慊ｮcisions importantes pour l''avenir des t笏慊ｮl笏慊ｮcommunications en Afrique. D笏慊ｮcouvrez les principaux votes et r笏慊ｮsolutions.', '笏慊ｮv笏慊ｮnement', 'UAT', 'https://images.unsplash.com/photo-1515187029135-18ee286d815b?w=1200', '2026-04-22 08:14:17.863291+00', true, 'UAT Communication', '4 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00', 'draft', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000009', 'L''笏慊ｮducation num笏慊ｮrique en Afrique de l''Est', 'Initiatives pour l''笏慊ｮducation num笏慊ｮrique dans la r笏慊ｮgion EAC.', 'Les pays de la Communaut笏慊ｮ d''Afrique de l''Est lancent des initiatives conjointes pour promouvoir l''笏慊ｮducation num笏慊ｮrique dans les 笏慊ｮcoles rurales.', '笏慊ｮducation', 'UAT-EAC', 'https://images.unsplash.com/photo-1509062522246-3755977927d7?w=1200', '2026-04-23 08:14:17.863291+00', true, 'Bureau EAC', '6 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00', 'draft', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000010', 'Financement innovant : Les obligations zones blanches', 'Comment les obligations de d笏慊ｮploiement financent le FSU.', 'Les obligations de couverture zones blanches repr笏慊ｮsentent un m笏慊ｮcanisme de financement innovant pour les Fonds de Service Universel.', 'financement', 'UAT', 'https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?w=1200', '2026-04-24 08:14:17.863291+00', true, 'Jean-Pierre Mbengue', '7 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00', 'draft', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000011', 'Infrastructure 5G : Le projet pilote du Nigeria', 'Le Nigeria lance son premier projet 5G 笏愿｡ Lagos.', 'Le Nigeria devient le premier pays de la r笏慊ｮgion 笏愿｡ lancer un projet pilote 5G avec le soutien du Fonds de Service Universel.', 'innovation', 'UAT', 'https://images.unsplash.com/photo-1557804506-669a67965ba0?w=1200', '2026-04-25 08:14:17.863291+00', true, 'D笏慊ｮl笏慊ｮgu笏慊ｮ Nigeria', '5 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00', 'draft', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000013', 'T笏慊ｮl笏慊ｮconsultation m笏慊ｮdicale en Afrique rurale', 'Comment la t笏慊ｮl笏慊ｮconsultation sauve des vies gr笏愿ｳce au FSU.', 'Le d笏慊ｮploiement d''infrastructures de t笏慊ｮl笏慊ｮcommunication dans les zones rurales permet le d笏慊ｮveloppement de services de t笏慊ｮl笏慊ｮconsultation m笏慊ｮdicale vitaux.', 'sant笏慊ｮ', 'UAT', 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=1200', '2026-04-26 12:14:17.863291+00', true, 'Dr. A笏慊ｻcha Kon笏慊ｮ', '6 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00', 'draft', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000012', 'Renforcement des capacit笏慊ｮs : Programme 2026-2030', 'Le nouveau programme de renforcement des capacit笏慊ｮs de l''UAT.', 'L''UAT lance un programme ambitieux de formation de 10 000 professionnels des t笏慊ｮl笏慊ｮcommunications d''ici 2030.', 'formation', 'UAT', 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=1200', '2026-04-26 08:14:17.863291+00', true, 'UAT Formation', '4 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 09:27:53.236787+00', 'published', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000014', 'L''agriculture num笏慊ｮrique en zone C笏慊ｮd笏慊ｮao', 'La transformation num笏慊ｮrique de l''agriculture en Afrique de l''Ouest.', 'Les projets de connectivit笏慊ｮ rurale financ笏慊ｮs par le FSU permettent le d笏慊ｮveloppement de solutions d''agriculture num笏慊ｮrique.', 'agriculture', 'UAT', 'https://images.unsplash.com/photo-1500937386664-56d1dfef3854?w=1200', '2026-04-26 14:14:17.863291+00', true, 'Bureau CEDEAO', '5 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 09:27:56.938988+00', 'published', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000016', 'Entreprenariat num笏慊ｮrique : Concours 2026', 'Lancement du concours d''entreprenariat num笏慊ｮrique de l''UAT.', 'L''UAT lance son concours d''entreprenariat num笏慊ｮrique pour soutenir les start-ups du secteur des t笏慊ｮl笏慊ｮcommunications.', 'concours', 'UAT', 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?w=1200', '2026-04-26 20:14:17.863291+00', true, 'UAT Innovation', '4 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 09:28:02.15289+00', 'published', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000017', 'Coop笏慊ｮration r笏慊ｮgionale : Accord UAT-UE', 'Nouvel accord de coop笏慊ｮration entre l''UAT et l''Union Europ笏慊ｮenne.', 'L''accord pr笏慊ｮvoit un financement de 200 millions d''euros pour les projets de connectivit笏慊ｮ en Afrique.', 'partenariat', 'UAT', 'https://eauxetforets.gouv.ci/sites/default/files/styles/page-actu-top/public/actualite/apv1.jpg?itok=Br6GV27r', '2026-04-26 22:14:17.863291+00', true, 'UAT Communication', '5 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 09:31:05.922415+00', 'published', '', '', '', '', 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000015', 'S笏慊ｮcurit笏慊ｮ des r笏慊ｮseaux : Nouvelles directives', 'Directives de l''UAT pour la s笏慊ｮcurit笏慊ｮ des r笏慊ｮseaux de t笏慊ｮl笏慊ｮcommunications.', 'L''UAT publie de nouvelles directives pour renforcer la cybers笏慊ｮcurit笏慊ｮ des r笏慊ｮseaux de t笏慊ｮl笏慊ｮcommunications nationaux.', 's笏慊ｮcurit笏慊ｮ', 'UAT', 'https://images.unsplash.com/photo-1563986768609-322da13575f3?w=1200', '2026-04-26 17:14:17.863291+00', true, 'UAT Technique', '7 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 09:27:43.314035+00', 'published', NULL, NULL, NULL, NULL, 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000018', 'Digitalisation des services publics', 'Comment le FSU finance la digitalisation administrative.', 'Les projets financ笏慊ｮs par le FSU permettent la digitalisation des services publics dans les zones rurales.', 'e-gouvernement', 'UAT', 'https://images.theconversation.com/files/625175/original/file-20241011-15-350guy.jpg?ixlib=rb-4.1.0&rect=0%2C0%2C4243%2C2828&q=50&auto=format&w=768&h=512&fit=crop&dpr=2', '2026-04-27 00:14:17.863291+00', true, 'Bureau SADC', '6 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 09:39:08.448239+00', 'published', '', '', '', '', 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000019', '笏愿ｫnergie solaire pour les sites t笏慊ｮl笏慊ｮcoms', 'Initiatives pour une t笏慊ｮl笏慊ｮcommunication verte en Afrique.', '<p>Les technologies de l''information et de la communication (TIC) jouent un r笏懌筈le essentiel dans la r笏慊ｮalisation du Programme 2030 pour le d笏慊ｮveloppement durable. La disponibilit笏慊ｮ de l''笏慊ｮnergie est indispensable au secteur des TIC, 笏愿｡ ses services et 笏愿｡ ses applications. L''笏慊ｮlectricit笏慊ｮ est n笏慊ｮcessaire pour la plupart des TIC, pour recharger les appareils, alimenter les stations de base mobiles, faire fonctionner les centres de donn笏慊ｮes et les r笏慊ｮseaux, pour ne citer que quelques exemples. L''acc笏慊ｿs 笏愿｡ une alimentation 笏慊ｮlectrique fiable et abordable reste une contrainte majeure, en particulier dans les pays les moins avanc笏慊ｮs (PMA), les pays en d笏慊ｮveloppement sans littoral (PDSL) et les petits 笏愿ｫtats insulaires en d笏慊ｮveloppement (PEID), ainsi que dans les zones rurales et recul笏慊ｮes, o笏懌淵 les populations pourraient tirer le meilleur parti du pouvoir de transformation des TIC, mais o笏懌淵 l''acc笏慊ｿs au r笏慊ｮseau 笏慊ｮlectrique est tr笏慊ｿs limit笏慊ｮ et les revenus faibles. Il existe une relation symbiotique entre l''笏慊ｮnergie et la connectivit笏慊ｮ 笏愿｡ Internet dans les endroits qui ne sont pas encore connect笏慊ｮs, notamment parce que les mod笏慊ｿles commerciaux hors r笏慊ｮseau reposent sur la connectivit笏慊ｮ pour la gestion 笏愿｡ distance. En outre, les mod笏慊ｿles commerciaux de connectivit笏慊ｮ b笏慊ｮn笏慊ｮficient de l''utilisation accrue des services mobiles, notamment des services financiers. Les r笏慊ｮseaux 笏慊ｮlectriques peuvent 笏慊ｮgalement 笏慊ｬtre exploit笏慊ｮs pour 笏慊ｮtendre les r笏慊ｮseaux dorsaux nationaux et ruraux large bande. Le partage et la r笏慊ｮutilisation des infrastructures peuvent constituer un outil important pour r笏慊ｮduire les co笏懌風ts et 笏慊ｮtendre les services, ce qui souligne l''importance de la coop笏慊ｮration et de la coordination entre les secteurs des TIC et de l''笏慊ｮnergie pour connecter les zones rurales. Bien qu''il existe un large 笏慊ｮventail de sources d''笏慊ｮnergie renouvelables, la fourniture de cette 笏慊ｮnergie par des m笏慊ｮthodes traditionnelles peut se r笏慊ｮv笏慊ｮler co笏懌風teuse. Le co笏懌風t prohibitif de l''installation et de l''entretien des lignes et des c笏愿ｳbles 笏慊ｮlectriques laisse souvent de nombreuses personnes dans les zones rurales sans source d''笏慊ｮnergie fiable. Dans de telles situations, l''espace et les nouvelles technologies large bande par satellite ainsi que des solutions innovantes comme les syst笏慊ｿmes de transmission d''笏慊ｮnergie sans fil peuvent offrir une voie vers une connectivit笏慊ｮ Internet 笏慊ｮconomique.</p>', 'environnement', 'UAT', 'https://images.unsplash.com/photo-1509391366360-2e959784a276?w=1200', '2026-04-27 02:14:17.863291+00', true, 'UAT Environnement', '5 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 09:42:07.047124+00', 'published', '', '', '', '', 0, false, true, NULL),
	('d0000000-0000-0000-0000-000000000020', 'Conf笏慊ｮrence Spectrum 2026', 'Pr笏慊ｮparatifs de la Conf笏慊ｮrence Spectrum 2026 笏愿｡ Nairobi.', '<p>Coorganis笏慊ｮ par le Forum sud-africain des r笏慊ｮgulateurs de lﾃ氾僌吠nformation, de la communication, des technologies et des m笏慊ｮdias, et le Social Media 4 Peace South Africa (SM4PSA), lﾃ氾僌問莫ﾂｮv笏慊ｮnement 笏慊ｮtait organis笏慊ｮ avec le soutien de lﾃ氾僌剖NESCO, du R笏慊ｮseau des autorit笏慊ｮs africaines de r笏慊ｮgulation de la communication (RIARC), du R笏慊ｮseau francophone des r笏慊ｮgulateurs des m笏慊ｮdias (REFRAM), du R笏慊ｮseau de connaissances I4T, ainsi que de lﾃ氾僌剖nion.</p><p>Cette deuxi笏慊ｿme 笏慊ｮdition a r笏慊ｮuni des r笏慊ｮgulateurs des m笏慊ｮdias et de la communication, des gouvernements, des autorit笏慊ｮs 笏慊ｮlectorales, des plateformes num笏慊ｮriques, des repr笏慊ｮsentants de la soci笏慊ｮt笏慊ｮ civile, du milieu acad笏慊ｮmique, ainsi que des organisations internationales et r笏慊ｮgionales de toutes les r笏慊ｮgions du monde, afin de faire progresser des approches de gouvernance num笏慊ｮrique fond笏慊ｮes sur les droits humains et le multiacteur, et dﾃ氾僌問莫ﾂｮvaluer les avanc笏慊ｮes r笏慊ｮalis笏慊ｮes dans la mise en 笏ｼﾃｴuvre desﾃ氾傔ｻ<a target="_blank" rel="noopener noreferrer nofollow" href="https://unesdoc.unesco.org/ark:/48223/pf0000387359"><u>Principes de lﾃ氾僌剖NESCO pour la gouvernance des plateformes num笏慊ｮriques</u></a>.&nbsp;</p><p>Des s笏慊ｮances pl笏慊ｮni笏慊ｿres publiques et des 笏慊ｮv笏慊ｮnements parall笏慊ｿles se sont d笏慊ｮroul笏慊ｮs tout au long de la conf笏慊ｮrence, pr笏慊ｮsentant des perspectives r笏慊ｮgionales, des discussions th笏慊ｮmatiques et une collaboration multipartite afin de renforcer la libert笏慊ｮ d''expression et l''int笏慊ｮgrit笏慊ｮ de l''information en ligne.&nbsp;</p><p>Cette conf笏慊ｮrence mondiale constituait 笏慊ｮgalement la deuxi笏慊ｿme r笏慊ｮunion annuelle du Forum mondial des r笏慊ｮseaux (GFN), lanc笏慊ｮ en 2024 笏愿｡ Dubrovnik, en Croatie, lors de la premi笏慊ｿre Conf笏慊ｮrence internationale sur la gouvernance des plateformes num笏慊ｮriques.&nbsp;</p>', '笏慊ｮv笏慊ｮnement', 'UAT', 'https://www.elearning-africa.com/conference2026/ressources/images/content/2024/home_countries_3.jpg', '2026-04-27 04:14:17.863291+00', true, 'UAT Communication', '3 min', 'fr', NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 09:43:39.818459+00', 'published', '', '', '', '', 0, false, true, NULL);


