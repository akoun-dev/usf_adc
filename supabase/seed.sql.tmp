INSERT INTO "public"."forum_posts" ("id", "topic_id", "created_by", "content", "is_solution", "created_at", "updated_at") VALUES
	('6998c43f-4717-4bf2-88dc-7d118a821132', '3129a76a-5d77-46da-80c6-3b32df92c47b', NULL, 'De mon exp笏慊ｮrience, il est crucial de combiner le financement gouvernemental avec les investissements priv笏慊ｮs pour maximiser les ressources du FSU.', false, '2026-04-03 08:14:16.752077+00', '2026-04-03 08:14:16.752077+00'),
	('97c98c92-e87b-4b8b-9d45-bc18cc09a068', '3129a76a-5d77-46da-80c6-3b32df92c47b', NULL, 'Absolument ! Au S笏慊ｮn笏慊ｮgal, nous avons utilis笏慊ｮ un mod笏慊ｿle mixte avec succ笏慊ｿs. Les op笏慊ｮrateurs priv笏慊ｮs contribuent 30% du financement.', true, '2026-04-04 08:14:16.752077+00', '2026-04-04 08:14:16.752077+00'),
	('9a0fa41b-e9a7-4e93-9156-8d71347fd9c0', 'd96d7d57-f5a0-48e8-a16e-600ba3d0dfde', NULL, 'Avez-vous v笏慊ｮrifi笏慊ｮ votre connexion internet ? Essayez de vider le cache de votre navigateur.', false, '2026-04-08 08:14:16.752077+00', '2026-04-08 08:14:16.752077+00'),
	('d735966f-98d3-4c1a-89dc-10a42d065dde', 'd96d7d57-f5a0-48e8-a16e-600ba3d0dfde', NULL, 'Cela a r笏慊ｮsolu mon probl笏慊ｿme ! Merci beaucoup.', true, '2026-04-09 08:14:16.752077+00', '2026-04-09 08:14:16.752077+00'),
	('afd5b4d3-b337-40d4-8cc4-934048d5cadd', '791b3df9-2c37-48da-95d8-b080b4a17aea', NULL, 'Nous avons lanc笏慊ｮ un projet pilote 5G au Nigeria avec le soutien du FSU. Les r笏慊ｮsultats sont tr笏慊ｿs prometteurs.', false, '2026-04-13 08:14:16.752077+00', '2026-04-13 08:14:16.752077+00'),
	('ba4276c0-17d9-4779-ac98-a3f434fc9a57', '103e321f-cdfd-489c-8af3-4a511adaca97', NULL, 'La fibre optique reste la solution la plus efficace pour les zones rurales, malgr笏慊ｮ les co笏懌風ts initiaux 笏慊ｮlev笏慊ｮs.', false, '2026-04-18 08:14:16.752077+00', '2026-04-18 08:14:16.752077+00'),
	('3ef1750e-3e8f-4d07-8c9f-0e3d60622572', '103e321f-cdfd-489c-8af3-4a511adaca97', NULL, 'D''accord, mais avez-vous consid笏慊ｮr笏慊ｮ les solutions par satellite pour les zones tr笏慊ｿs recul笏慊ｮes ?', false, '2026-04-19 08:14:16.752077+00', '2026-04-19 08:14:16.752077+00'),
	('4697c61c-184d-41dc-9525-d63e20035945', '420a214b-a2da-4286-9747-e9c097a2526c', NULL, 'Au Kenya, le partenariat PPP avec Safaricom a permis d''笏慊ｮtendre la couverture mobile 笏愿｡ 85% du pays.', false, '2026-04-23 08:14:16.752077+00', '2026-04-23 08:14:16.752077+00');


