	('d0000000-0000-0000-0000-000000000001', 'Sommet Africa Tech 2026', 'Le plus grand rassemblement des acteurs du num笏慊ｮrique en Afrique. 笏愿ｫditions pr笏慊ｮc笏慊ｮdentes : 3000 participants, 50 pays repr笏慊ｮsent笏慊ｮs, 200 conf笏慊ｮrenciers.', '2026-05-15 09:00:00+00', '2026-05-18 18:00:00+00', 'Palais des Congr笏慊ｿs, Abidjan, C笏懌筈te d''Ivoire', 'conference', 'upcoming', 3000, 'https://atuuat.africa/events/africa-tech-2025', 'Gratuit sur invitation', 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=1200&h=630&fit=crop', 'Union Africaine des T笏慊ｮl笏慊ｮcommunications', true, NULL, NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00'),
	('d0000000-0000-0000-0000-000000000002', 'Webinaire : Strat笏慊ｮgies de mobilisation du FSU', 'D笏慊ｮcouvrez les strat笏慊ｮgies efficaces pour mobiliser les ressources du Fonds de Service Universel.', '2026-05-22 14:00:00+00', '2026-05-22 17:00:00+00', 'En ligne', 'webinar', 'upcoming', 500, 'https://atuuat.africa/webinars/fsu-financement', 'Gratuit', 'https://images.unsplash.com/photo-1573164713988-8665fc963095?w=1200&h=630&fit=crop', 'UAT - Programmes', true, NULL, NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00'),
	('d0000000-0000-0000-0000-000000000003', 'Atelier Pratique : Gestion de la plateforme USF-ADC', 'Formation pratique intensive sur l''utilisation de la plateforme USF-ADC pour les Points Focaux et Administrateurs Pays.', '2026-06-10 09:00:00+00', '2026-06-12 17:00:00+00', 'H笏懌筈tel Noom, Ouagadougou, Burkina Faso', 'workshop', 'upcoming', 40, 'https://atuuat.africa/training/usf-adc', 'Gratuit (frais de voyage pris en charge)', 'https://images.unsplash.com/photo-1543269664-76bc3997d9ea?w=1200&h=630&fit=crop', 'UAT - Formation', true, NULL, NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00'),
	('d0000000-0000-0000-0000-000000000004', 'Conf笏慊ｮrence R笏慊ｮgionale : L''Inclusion Num笏慊ｮrique au Sahel', 'Une conf笏慊ｮrence d笏慊ｮdi笏慊ｮe aux d笏慊ｮfis et opportunit笏慊ｮs de l''inclusion num笏慊ｮrique dans la r笏慊ｮgion du Sahel.', '2026-07-08 09:00:00+00', '2026-07-10 17:00:00+00', 'Centre de Conf笏慊ｮrences, Niamey, Niger', 'conference', 'upcoming', 300, 'https://atuuat.africa/events/sahel-inclusion', 'Gratuit', 'https://images.unsplash.com/photo-1497366754035-f200968a6e72?w=1200&h=630&fit=crop', 'UAT - R笏慊ｮgion Sahel', true, NULL, NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00'),
	('d0000000-0000-0000-0000-000000000005', 'Session de Certification : Auditeurs du FSU', 'Programme de certification pour devenir auditeur qualifi笏慊ｮ des Fonds de Service Universel.', '2026-08-24 09:00:00+00', '2026-08-28 17:00:00+00', 'Institut Sup笏慊ｮrieur des T笏慊ｮl笏慊ｮcommunications, Dakar, S笏慊ｮn笏慊ｮgal', 'training', 'upcoming', 25, 'https://atuuat.africa/certification/audit', '500 000 FCFA (hors frais de voyage)', 'https://images.unsplash.com/photo-1556761175-b413da4baf72?w=1200&h=630&fit=crop', 'UAT - Certification', true, NULL, NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00'),
	('d0000000-0000-0000-0000-000000000006', 'Forum annuel : Partenariats Public-Priv笏慊ｮ pour le FSU', 'Le forum annuel de l''UAT sur les partenariats public-priv笏慊ｮ comme levier de financement du Service Universel.', '2026-09-20 09:00:00+00', '2026-09-22 17:00:00+00', 'Kempinski, Accra, Ghana', 'conference', 'upcoming', 200, 'https://atuuat.africa/events/ppp-forum', '200 000 FCFA (early bird: 150 000 FCFA)', 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=1200&h=630&fit=crop', 'UAT - Partenariats', true, NULL, NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00'),
	('d0000000-0000-0000-0000-000000000007', 'Hackathon : Solutions innovantes pour le FSU', '48 heures pour imaginer et prototyper des solutions innovantes au service du Fonds de Service Universel.', '2026-10-25 09:00:00+00', '2026-10-27 18:00:00+00', 'Technopark, Kigali, Rwanda', 'workshop', 'upcoming', 150, 'https://atuuat.africa/hackathon/fsu', 'Gratuit (sur s笏慊ｮlection)', 'https://images.unsplash.com/photo-1531482615713-2afd69097998?w=1200&h=630&fit=crop', 'UAT - Innovation', true, NULL, NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00'),
	('d0000000-0000-0000-0000-000000000008', 'Webinaire : Financement 5G en Afrique', 'Strat笏慊ｮgies de financement pour le d笏慊ｮploiement de la 5G en Afrique.', '2026-06-15 15:00:00+00', '2026-06-15 17:00:00+00', 'En ligne', 'webinar', 'upcoming', 1000, 'https://atuuat.africa/webinars/5g-funding', 'Gratuit', 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=1200&h=630&fit=crop', 'UAT - T笏慊ｮl笏慊ｮcom', true, NULL, NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00'),
	('d0000000-0000-0000-0000-000000000009', 'Conf笏慊ｮrence : Connectivit笏慊ｮ rurale', 'Solutions innovantes pour connecter les zones rurales africaines.', '2026-08-05 09:00:00+00', '2026-08-06 17:00:00+00', 'Hotel Serena, Kigali, Rwanda', 'conference', 'upcoming', 250, 'https://atuuat.africa/events/rural-connectivity', '150 000 FCFA', 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=1200&h=630&fit=crop', 'UAT - Infrastructure', true, NULL, NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00'),
	('d0000000-0000-0000-0000-000000000010', 'Atelier : Gouvernance des FSU', 'Formation 笏愿｡ la gouvernance et la transparence des Fonds de Service Universel.', '2026-09-05 09:00:00+00', '2026-09-07 17:00:00+00', 'Radisson Blu, Dakar, S笏慊ｮn笏慊ｮgal', 'workshop', 'upcoming', 60, 'https://atuuat.africa/workshops/fsu-governance', 'Gratuit pour membres', 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=1200&h=630&fit=crop', 'UAT - Gouvernance', true, NULL, NULL, '2026-04-27 08:14:17.863291+00', '2026-04-27 08:14:17.863291+00');


