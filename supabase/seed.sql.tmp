INSERT INTO "public"."faq_articles" ("id", "title", "content", "category", "sort_order", "is_published", "created_at", "updated_at") VALUES
	('0da1680a-fdca-4f72-ba46-9b8cdef9e3fc', 'Comment cr笏慊ｮer un compte ?', 'Pour cr笏慊ｮer un compte, cliquez sur le bouton "S''inscrire" en haut 笏愿｡ droite de la page. Remplissez le formulaire avec vos informations et validez votre adresse email.', 'general', 1, true, '2026-04-27 08:14:17.227269+00', '2026-04-27 08:14:17.227269+00'),
	('945059cb-be13-4118-ad44-c4084a7e0bca', 'Comment r笏慊ｮinitialiser mon mot de passe ?', 'Cliquez sur "Mot de passe oubli笏慊ｮ" sur la page de connexion. Entrez votre adresse email et suivez les instructions envoy笏慊ｮes par email.', 'account', 1, true, '2026-04-27 08:14:17.227269+00', '2026-04-27 08:14:17.227269+00'),
	('b2d08a95-f832-4f21-9e81-d720c27cf1a9', 'Qu''est-ce qu''une soumission FSU ?', 'Une soumission FSU (Forum des Syndicats Unifi笏慊ｮs) est un document ou une information soumise par votre syndicat pour partage et validation.', 'fsu', 1, true, '2026-04-27 08:14:17.227269+00', '2026-04-27 08:14:17.227269+00'),
	('a282ac66-4aaf-4556-b54f-e3d60e96d311', 'Comment soumettre un document FSU ?', 'Allez dans la section FSU, cliquez sur "Nouvelle soumission", remplissez le formulaire et ajoutez vos pi笏慊ｿces jointes.', 'fsu', 2, true, '2026-04-27 08:14:17.227269+00', '2026-04-27 08:14:17.227269+00');


